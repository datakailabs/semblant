---
interface Props {
  lastUpdated: string;
}

const { lastUpdated } = Astro.props;
---

<footer class="max-w-4xl mx-auto px-6 py-12 no-print">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--color-text-muted)]">
    <div class="flex items-center gap-4">
      <a
        href="/api/resume/pdf"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[var(--color-accent)] text-white font-medium hover:opacity-90 transition-opacity"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Download PDF
      </a>
    </div>

    <span>
      Last updated {lastUpdated} · Built with
      <a href="https://github.com/datakailabs/semblant" target="_blank" rel="noopener noreferrer"
         class="hover:text-[var(--color-accent)] transition-colors">
        Semblant
      </a>
    </span>
  </div>
</footer>
