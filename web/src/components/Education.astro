---
import type { Education } from '../lib/resume';

interface Props {
  education: Education[];
}

const { education } = Astro.props;
---

<section id="education">
  <h2 class="section-title">Education</h2>

  <div class="space-y-4">
    {education.map((edu) => (
      <div class="card">
        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <div>
            <h3 class="font-semibold">{edu.degree}</h3>
            <p class="text-sm accent-text">{edu.institution}</p>
          </div>
          <div class="text-right">
            {(edu.start || edu.end) && (
              <span class="text-sm text-[var(--color-text-muted)] font-mono">
                {edu.start}{edu.start && edu.end && ' — '}{edu.end}
              </span>
            )}
            {edu.location && (
              <p class="text-sm text-[var(--color-text-muted)]">{edu.location}</p>
            )}
          </div>
        </div>
        {edu.notes && (
          <p class="text-sm text-[var(--color-text-muted)] mt-2">{edu.notes}</p>
        )}
      </div>
    ))}
  </div>
</section>
